{
    "name": "makraz/ux-vvvebjs",
    "type": "symfony-bundle",
    "description": "Symfony UX Bundle for VvvebJs drag-and-drop page builder",
    "keywords": [
        "symfony-ux",
        "symfony ux",
        "symfony form",
        "symfony page builder",
        "symfony vvvebjs",
        "symfony ux bundle",
        "vvvebjs",
        "page builder",
        "drag and drop",
        "website builder",
        "easyadmin",
        "easyadmin page builder"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Hamza Makraz",
            "homepage": "https://github.com/makraz"
        }
    ],
    "homepage": "https://github.com/makraz/ux-vvvebjs",
    "support": {
        "issues": "https://github.com/makraz/ux-vvvebjs/issues",
        "source": "https://github.com/makraz/ux-vvvebjs"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": ">=8.1.0",
        "symfony/stimulus-bundle": "^2.9.1",
        "symfony/twig-bundle": "^6.4|^7.0|^8.0",
        "symfony/form": "^6.4|^7.0|^8.0",
        "symfony/routing": "^6.4|^7.0|^8.0",
        "symfony/string": "^6.4|^7.0|^8.0"
    },
    "suggest": {
        "league/flysystem-bundle": "Required for Flysystem upload handler support"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5|^10.0|^11.0",
        "friendsofphp/php-cs-fixer": "^3.1",
        "symfony/browser-kit": "^6.4|^7.0|^8.0",
        "symfony/framework-bundle": "^6.4|^7.0|^8.0",
        "symfony/asset-mapper": "^6.4|^7.0|^8.0",
        "easycorp/easyadmin-bundle": "^4.7"
    },
    "autoload": {
        "psr-4": {
            "Makraz\\VvvebJsBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Makraz\\VvvebJsBundle\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "symfony/flex": true
        }
    },
    "extra": {
        "thanks": {
            "name": "symfony/ux",
            "url": "https://github.com/symfony/ux"
        }
    }
}
