{
    "name": "@makraz/ux-vvvebjs",
    "description": "Symfony UX bundle for VvvebJs drag-and-drop page builder",
    "type": "module",
    "version": "1.0.0",
    "license": "MIT",
    "files": [
        "dist"
    ],
    "main": "dist/controller.js",
    "types": "dist/controller.d.ts",
    "repository": {
        "type": "git",
        "url": "https://github.com/makraz/ux-vvvebjs"
    },
    "symfony": {
        "controllers": {
            "vvvebjs": {
                "main": "dist/controller.js",
                "webpackMode": "eager",
                "fetch": "eager",
                "enabled": true
            }
        },
        "importmap": {
            "@hotwired/stimulus": "^3.0.0"
        }
    },
    "peerDependencies": {
        "@hotwired/stimulus": "^3.0.0"
    },
    "devDependencies": {
        "@babel/cli": "^7.20.7",
        "@babel/core": "^7.20.12",
        "@babel/preset-env": "^7.20.2",
        "@babel/preset-typescript": "^7.18.6",
        "@hotwired/stimulus": "^3.2.1",
        "typescript": "^5.0.0"
    },
    "scripts": {
        "build": "babel src --extensions .ts -d dist",
        "watch": "babel src --out-dir dist --source-maps --watch --extensions '.ts,.js'"
    }
}
